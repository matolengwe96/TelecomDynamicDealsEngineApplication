# ============================================================
# DDE Enterprise — Environment Variables Reference
# Copy to .env and fill in secrets before running.
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development

# ── PostgreSQL (shared host, isolated databases per service) ─
POSTGRES_USER=dde_user
POSTGRES_PASSWORD=dde_pass
# Each service gets its own database — created automatically on first postgres start.
# Local dev (non-Docker):
AUTH_DB_URL=postgresql://dde_user:dde_pass@localhost:5432/dde_auth
CYCLE_DB_URL=postgresql://dde_user:dde_pass@localhost:5432/dde_cycle
CATALOG_DB_URL=postgresql://dde_user:dde_pass@localhost:5432/dde_catalog
TRADELIST_DB_URL=postgresql://dde_user:dde_pass@localhost:5432/dde_tradelist
OEM_DB_URL=postgresql://dde_user:dde_pass@localhost:5432/dde_oem
HEADLINE_DB_URL=postgresql://dde_user:dde_pass@localhost:5432/dde_headline
APPROVAL_DB_URL=postgresql://dde_user:dde_pass@localhost:5432/dde_approval
CHANNEL_DEALS_DB_URL=postgresql://dde_user:dde_pass@localhost:5432/dde_channel_deals
JOB_DB_URL=postgresql://dde_user:dde_pass@localhost:5432/dde_job
NOTIFICATION_DB_URL=postgresql://dde_user:dde_pass@localhost:5432/dde_notification
AUDIT_DB_URL=postgresql://dde_user:dde_pass@localhost:5432/dde_audit

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── RabbitMQ ──────────────────────────────────────────────────
RABBITMQ_USER=dde_user
RABBITMQ_PASS=dde_pass
# amqp://<user>:<pass>@<host>:5672/<vhost>
RABBITMQ_URL=amqp://dde_user:dde_pass@localhost:5672/dde

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Internal service-to-service secret ───────────────────────
# All downstream services reject requests without this header.
INTERNAL_SERVICE_SECRET=change-me-internal-secret-in-production

# ── Service URLs (local non-Docker dev overrides) ────────────
AUTH_SERVICE_URL=http://localhost:3011
CYCLE_SERVICE_URL=http://localhost:3002
CATALOG_SERVICE_URL=http://localhost:3003
TRADELIST_SERVICE_URL=http://localhost:3004
OEM_SERVICE_URL=http://localhost:3005
HEADLINE_SERVICE_URL=http://localhost:3006
APPROVAL_SERVICE_URL=http://localhost:3007
CHANNEL_DEALS_SERVICE_URL=http://localhost:3008
JOB_SERVICE_URL=http://localhost:3009
NOTIFICATION_SERVICE_URL=http://localhost:3010
AUDIT_SERVICE_URL=http://localhost:3012

# ── Frontend ──────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001

# ── Email / SMTP (notification-service) ──────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=changeme
SMTP_FROM=DDE System <noreply@example.com>

# ── File uploads ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
