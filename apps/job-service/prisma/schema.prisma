generator client { provider = "prisma-client-js" }

datasource db {
  provider = "postgresql"
  url      = env("JOB_DB_URL")
}

model JobRun {
  id              String    @id @default(uuid())
  jobType         String
  status          String    @default("QUEUED") // QUEUED, RUNNING, SUCCEEDED, FAILED, PARTIAL_SUCCESS, RETRIED
  correlationId   String?
  payload         Json?
  result          Json?
  error           String?
  retryCount      Int       @default(0)
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([jobType])
  @@index([status])
  @@map("enr_job_runs")
}
