{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "ES2022",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@dde/contracts": ["../../packages/contracts/src"],
      "@dde/events": ["../../packages/events/src"],
      "@dde/config": ["../../packages/config/src"]
    }
  },
  "include": ["src/**/*", "prisma/**/*"],
  "exclude": ["node_modules", "dist"]
}
